# Guide

guide: {
  metrics: count: entity: 3
  metrics: count: path: 4
  metrics: count: method: 4

  entity: lonlongitude: {
    path: "/textParts/lat={latitude}/lon={longitude}": {
      op: list: method: *GET
    }
  }

  entity: reverse_geocoding: {
    path: "/text": {
      op: load: method: *GET
    }
    path: "/text/lat={latitude}/lon={longitude}": {
      op: load: method: *GET
    }
  }

  entity: text_part: {
    path: "/textParts": {
      op: list: method: *GET
    }
  }

}